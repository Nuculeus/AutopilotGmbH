# App / Wrapper public URL
APP_DOMAIN=example.com
NODE_ENV=production
APP_BASE_URL=https://example.com
NEXT_PUBLIC_APP_URL=https://example.com
NEXT_PUBLIC_APP_NAME=AutopilotGmbH

# Wrapper / Next.js
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_clerk_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/launch
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/launch

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_STARTER_PRICE_ID=price_replace_me

# Clerk
CLERK_SECRET_KEY=sk_test_clerk_replace_me
CLERK_SIGN_IN_URL=/sign-in
CLERK_SIGN_UP_URL=/sign-up
CLERK_AFTER_SIGN_IN_URL=/launch
CLERK_AFTER_SIGN_UP_URL=/launch

# Model provider keys
ANTHROPIC_API_KEY=sk-ant-replace_me
OPENAI_API_KEY=sk-proj-replace_me
OPENAI_BRIEFING_MODEL=gpt-4o-mini

# Database
POSTGRES_DB=autopilot_gmbh
POSTGRES_USER=autopilot
POSTGRES_PASSWORD=autopilot_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://autopilot:autopilot_dev_password@postgres:5432/autopilot_gmbh

# Paperclip runtime
PAPERCLIP_PORT=3100
PAPERCLIP_INTERNAL_URL=http://paperclip:3100
PAPERCLIP_API_URL=http://paperclip:3100
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
PAPERCLIP_AUTH_DISABLE_SIGN_UP=true
PAPERCLIP_ALLOWED_HOSTNAMES=paperclip
BETTER_AUTH_SECRET=replace_me_with_a_long_random_auth_secret
PAPERCLIP_AGENT_JWT_SECRET=replace_me_with_a_long_random_agent_secret
INTERNAL_BRIDGE_SECRET=replace_me_with_a_long_random_secret

# Wrapper bridge guardrails
PAPERCLIP_BRIDGE_READS_PER_MINUTE=30
PAPERCLIP_BRIDGE_WRITES_PER_MINUTE=6
PAPERCLIP_BRIDGE_WORKSPACE_API_READS_PER_MINUTE=1200
PAPERCLIP_BRIDGE_WORKSPACE_API_WRITES_PER_MINUTE=240

# Admin-only test bypass (never enable for broad user cohorts)
AUTOPILOT_ENABLE_ADMIN_BILLING_BYPASS=false
AUTOPILOT_ADMIN_USER_IDS=
AUTOPILOT_ADMIN_EMAILS=

# Multi-tenant / privacy
DEFAULT_TENANT_SLUG=demo-tenant
TENANT_DATA_ROOT=/data/tenants
EU_REGION=enforced
